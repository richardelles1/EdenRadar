210 20% 86%;\n  --sidebar-accent-foreground: 220 30% 12%;\n  --sidebar-ring: 142 52% 36%;\n  --popover: 210 20% 92%;\n  --popover-foreground: 220 30% 12%;\n  --popover-border: 210 15% 84%;\n  --primary: 142 52% 36%;\n  --primary-foreground: 0 0% 100%;\n  --secondary: 210 20% 86%;\n  --secondary-foreground: 220 30% 12%;\n  --muted: 210 15% 90%;\n  --muted-foreground: 220 20% 40%;\n  --accent: 210 20% 88%;\n  --accent-foreground: 220 30% 12%;\n  --destructive: 0 72% 45%;\n  --destructive-foreground: 0 0% 98%;\n  --input: 210 20% 75%;\n  --ring: 142 52% 36%;\n  --chart-1: 142 52% 36%;\n  --chart-2: 35 75% 52%;\n  --chart-3: 280 65% 42%;\n  --chart-4: 25 85% 48%;\n  --chart-5: 340 75% 45%;\n  --font-sans: Open Sans, sans-serif;\n  --font-serif: Georgia, serif;\n  --font-mono: Menlo, monospace;\n  --radius: .5rem;\n  --shadow-2xs: 0px 2px 0px 0px hsl(210 12% 50% / 0.00);\n  --shadow-xs: 0px 2px 0px 0px hsl(210 12% 50% / 0.00);\n  --shadow-sm: 0px 2px 0px 0px hsl(210 12% 50% / 0.00), 0px 1px 2px -1px hsl(210 12% 50% / 0.00);\n  --shadow: 0px 2px 0px 0px hsl(210 12% 50% / 0.00), 0px 1px 2px -1px hsl(210 12% 50% / 0.00);\n  --shadow-md: 0px 2px 0px 0px hsl(210 12% 50% / 0.00), 0px 2px 4px -1px hsl(210 12% 50% / 0.00);\n  --shadow-lg: 0px 2px 0px 0px hsl(210 12% 50% / 0.00), 0px 4px 6px -1px hsl(210 12% 50% / 0.00);\n  --shadow-xl: 0px 2px 0px 0px hsl(210 12% 50% / 0.00), 0px 8px 10px -1px hsl(210 12% 50% / 0.00);\n  --shadow-2xl: 0px 2px 0px 0px hsl(210 12% 50% / 0.00);\n  --tracking-normal: 0em;\n  --spacing: 0.25rem;\n\n/* Fallback for older browsers */\n  --sidebar-primary-border: hsl(var(--sidebar-primary));\n  --sidebar-primary-border: hsl(from hsl(var(--sidebar-primary)) h s calc(l + var(--opaque-button-border-intensity)) / alpha);\n\n  /* Fallback for older browsers */\n  --sidebar-accent-border: hsl(var(--sidebar-accent));\n  --sidebar-accent-border: hsl(from hsl(var(--sidebar-accent)) h s calc(l + var(--opaque-button-border-intensity)) / alpha);\n\n  /* Fallback for older browsers */\n  --primary-border: hsl(var(--primary));\n  --primary-border: hsl(from hsl(var(--primary)) h s calc(l + var(--opaque-button-border-intensity)) / alpha);\n\n  /* Fallback for older browsers */\n  --secondary-border: hsl(var(--secondary));\n  --secondary-border: hsl(from hsl(var(--secondary)) h s calc(l + var(--opaque-button-border-intensity)) / alpha);\n\n  /* Fallback for older browsers */\n  --muted-border: hsl(var(--muted));\n  --muted-border: hsl(from hsl(var(--muted)) h s calc(l + var(--opaque-button-border-intensity)) / alpha);\n\n  /* Fallback for older browsers */\n  --accent-border: hsl(var(--accent));\n  --accent-border: hsl(from hsl(var(--accent)) h s calc(l + var(--opaque-button-border-intensity)) / alpha);\n\n  /* Fallback for older browsers */\n  --destructive-border: hsl(var(--destructive));\n  --destructive-border: hsl(from hsl(var(--destructive)) h s calc(l + var(--opaque-button-border-intensity)) / alpha);\n}\n\n.dark {\n  --button-outline: rgba(255,255,255, .10);\n  --badge-outline: rgba(255,255,255, .05);\n  --opaque-button-border-intensity: 9;\n  --elevate-1: rgba(255,255,255, .03);\n  --elevate-2: rgba(255,255,255, .07);\n  --background: 222 47% 6%;\n  --foreground: 210 20% 92%;\n  --border: 222 35% 16%;\n  --card: 222 40% 9%;\n  --card-foreground: 210 20% 92%;\n  --card-border: 222 35% 14%;\n  --sidebar: 222 42% 8%;\n  --sidebar-foreground: 210 20% 92%;\n  --sidebar-border: 222 35% 13%;\n  --sidebar-primary: 142 65% 48%;\n  --sidebar-primary-foreground: 222 47% 6%;\n  --sidebar-accent: 222 35% 14%;\n  --sidebar-accent-foreground: 210 20% 92%;\n  --sidebar-ring: 142 65% 48%;\n  --popover: 222 42% 11%;\n  --popover-foreground: 210 20% 92%;\n  --popover-border: 222 35% 16%;\n  --primary: 142 65% 48%;\n  --primary-foreground: 222 47% 6%;\n  --secondary: 222 35% 15%;\n  --secondary-foreground: 210 20% 92%;\n  --muted: 222 35% 14%;\n  --muted-foreground: 210 15% 58%;\n  --accent: 222 35% 13%;\n  --accent-foreground: 210 20% 92%;\n  --destructive: 0 72% 48%;\n  --destructive-foreground: 0 0% 98%;\n  --input: 222 30% 18%;\n  --ring: 142 65% 48%;\n  --chart-1: 142 70% 55%;\n  --chart-2: 35 80% 65%;\n  --chart-3: 280 65% 68%;\n  --chart-4: 25 85% 65%;\n  --chart-5: 340 75% 65%;\n  --shadow-2xs: 0px 2px 0px 0px hsl(222 40% 3% / 0.60);\n  --shadow-xs: 0px 2px 0px 0px hsl(222 40% 3% / 0.40);\n  --shadow-sm: 0px 2px 4px 0px hsl(222 40% 3% / 0.40), 0px 1px 2px -1px hsl(222 40% 3% / 0.40);\n  --shadow: 0px 2px 4px 0px hsl(222 40% 3% / 0.50), 0px 1px 2px -1px hsl(222 40% 3% / 0.40);\n  --shadow-md: 0px 4px 8px 0px hsl(222 40% 3% / 0.50), 0px 2px 4px -1px hsl(222 40% 3% / 0.40);\n  --shadow-lg: 0px 8px 16px 0px hsl(222 40% 3% / 0.50), 0px 4px 6px -1px hsl(222 40% 3% / 0.40);\n  --shadow-xl: 0px 16px 32px 0px hsl(222 40% 3% / 0.60), 0px 8px 10px -1px hsl(222 40% 3% / 0.50);\n  --shadow-2xl: 0px 24px 48px 0px hsl(222 40% 3% / 0.70);\n\n/* Fallback for older browsers */\n  --sidebar-primary-border: hsl(var(--sidebar-primary));\n  --sidebar-primary-border: hsl(from hsl(var(--sidebar-primary)) h s calc(l + var(--opaque-button-border-intensity)) / alpha);\n\n  /* Fallback for older browsers */\n  --sidebar-accent-border: hsl(var(--sidebar-accent));\n  --sidebar-accent-border: hsl(from hsl(var(--sidebar-accent)) h s calc(l + var(--opaque-button-border-intensity)) / alpha);\n\n  /* Fallback for older browsers */\n  --primary-border: hsl(var(--primary));\n  --primary-border: hsl(from hsl(var(--primary)) h s calc(l + var(--opaque-button-border-intensity)) / alpha);\n\n  /* Fallback for older browsers */\n  --secondary-border: hsl(var(--secondary));\n  --secondary-border: hsl(from hsl(var(--secondary)) h s calc(l + var(--opaque-button-border-intensity)) / alpha);\n\n  /* Fallback for older browsers */\n  --muted-border: hsl(var(--muted));\n  --muted-border: hsl(from hsl(var(--muted)) h s calc(l + var(--opaque-button-border-intensity)) / alpha);\n\n  /* Fallback for older browsers */\n  --accent-border: hsl(var(--accent));\n  --accent-border: hsl(from hsl(var(--accent)) h s calc(l + var(--opaque-button-border-intensity)) / alpha);\n\n  /* Fallback for older browsers */\n  --destructive-border: hsl(var(--destructive));\n  --destructive-border: hsl(from hsl(var(--destructive)) h s calc(l + var(--opaque-button-border-intensity)) / alpha);\n}\n\n/* Radar sweep animation */\n@keyframes radar-sweep {\n  from { transform: rotate(0deg); }\n  to   { transform: rotate(360deg); }\n}\n\n/* Garden scroll animation */\n@keyframes garden-scroll {\n  from { transform: translateY(0); }\n  to   { transform: translateY(-50%); }\n}\n\n@keyframes eden-pulse {\n  0%, 100% { opacity: 0.45; }\n  50% { opacity: 1; }\n}\n\n/* Glow pulse */\n@keyframes glow-pulse {\n  0%, 100% { opacity: 0.5; }\n  50% { opacity: 1; }\n}\n\n/* Scan line */\n@keyframes scan-line {\n  0%   { transform: translateY(-100%); opacity: 0; }\n  10%  { opacity: 1; }\n  90%  { opacity: 1; }\n  100% { transform: translateY(100vh); opacity: 0; }\n}\n\n.radar-sweep {\n  animation: radar-sweep 4s linear infinite;\n  transform-origin: center center;\n}\n\n.garden-scroll {\n  animation: garden-scroll 14s linear infinite;\n}\n\n.eden-node {\n  animation: eden-pulse 2.8s ease-in-out infinite;\n}\n\n.glow-pulse {\n  animation: glow-pulse 2.5s ease-in-out infinite;\n}\n\n/* Particle background drift */\n@keyframes particle-drift {\n  0%, 100% { transform: translateY(0px) translateX(0px); opacity: 0.25; }\n  33%       { transform: translateY(-14px) translateX(6px); opacity: 0.6; }\n  66%       { transform: translateY(-7px) translateX(-8px); opacity: 0.4; }\n}\n\n/* Portal lab ring expand */\n@keyframes lab-ring-expand {\n  0%   { transform: scale(0.1); opacity: 0.12; }\n  100% { transform: scale(4);   opacity: 0; }\n}\n\n/* Portal particle drift */\n@keyframes portal-particle-drift {\n  0%, 100% { transform: translateY(0px) translateX(0px); opacity: 0.04; }\n  25%       { transform: translateY(-20px) translateX(10px); opacity: 0.07; }\n  50%       { transform: translateY(-35px) translateX(-8px); opacity: 0.05; }\n  75%       { transform: translateY(-15px) translateX(-12px); opacity: 0.06; }\n}\n\n/* Large background radar (slow) */\n@keyframes radar-bg-slow {\n  from { transform: rotate(0deg); }\n  to   { transform: rotate(360deg); }\n}\n\n/* Scroll-reveal fade up */\n@keyframes fade-up {\n  from { opacity: 0; transform: translateY(28px); }\n  to   { opacity: 1; transform: translateY(0); }\n}\n\n/* Pulsing ring (hero center) */\n@keyframes pulse-ring {\n  0%   { transform: scale(0.6); opacity: 0.5; }\n  100% { transform: scale(1.8); opacity: 0; }\n}\n\n.reveal-section {\n  opacity: 0;\n  transform: translateY(28px);\n}\n\n.reveal-section.is-visible {\n  animation: fade-up 0.65s ease-out forwards;\n}\n\n@media (prefers-reduced-motion: reduce) {\n  .reveal-section, .reveal-section.is-visible,\n  .radar-sweep, .garden-scroll, .eden-node, .glow-pulse,\n  .portal-bg-anim {\n    animation: none !important;\n    opacity: 1 !important;\n    transform: none !important;\n  }\n}\n\n/* ============================================================\n   LOGIN PAGE — Aurora + Radar background animations\n   ============================================================ */\n@keyframes aurora-blob-1 {\n  0%, 100% { transform: translate(0, 0) scale(1); opacity: 0.55; }\n  25%       { transform: translate(40px, -30px) scale(1.12); opacity: 0.70; }\n  50%       { transform: translate(-25px, 35px) scale(0.93); opacity: 0.60; }\n  75%       { transform: translate(30px, 15px) scale(1.07); opacity: 0.75; }\n}\n@keyframes aurora-blob-2 {\n  0%, 100% { transform: translate(0, 0) scale(1); opacity: 0.40; }\n  33%       { transform: translate(-50px, 25px) scale(1.18); opacity: 0.60; }\n  66%       { transform: translate(35px, -40px) scale(0.88); opacity: 0.48; }\n}\n@keyframes aurora-blob-3 {\n  0%, 100% { transform: translate(0, 0) scale(1); opacity: 0.35; }\n  40%       { transform: translate(-30px, -20px) scale(1.22); opacity: 0.55; }\n  80%       { transform: translate(20px, 30px) scale(0.92); opacity: 0.42; }\n}\n@keyframes radar-ring-expand {\n  0%   { transform: scale(0.5); opacity: 0.5; }\n  100% { transform: scale(2.5); opacity: 0; }\n}\n@keyframes radar-sweep-login {\n  from { transform: rotate(0deg); }\n  to   { transform: rotate(360deg); }\n}\n\n.aurora-blob-1 { animation: aurora-blob-1 13s ease-in-out infinite; }\n.aurora-blob-2 { animation: aurora-blob-2 10s ease-in-out infinite; }\n.aurora-blob-3 { animation: aurora-blob-3 16s ease-in-out infinite; }\n.radar-ring-1  { animation: radar-ring-expand 4s ease-out infinite; }\n.radar-ring-2  { animation: radar-ring-expand 4s ease-out 1.33s infinite; }\n.radar-ring-3  { animation: radar-ring-expand 4s ease-out 2.66s infinite; }\n.radar-spin    { animation: radar-sweep-login 6s linear infinite; transform-origin: center; }\n\n@media (prefers-reduced-motion: reduce) {\n  .aurora-blob-1, .aurora-blob-2, .aurora-blob-3,\n  .radar-ring-1, .radar-ring-2, .radar-ring-3, .radar-spin {\n    animation: none !important;\n    opacity: 0.3 !important;\n  }\n}\n\n/* Pitch deck chat — hide scrollbar visually, keep scroll function */\n.pitch-chat-scroll::-webkit-scrollbar {\n  display: none;\n}\n\n/* Gradient text utility */\n.gradient-text {\n  background: linear-gradient(135deg, hsl(142 52% 36%) 0%, hsl(142 48% 32%) 100%);\n  -webkit-background-clip: text;\n  -webkit-text-fill-color: transparent;\n  background-clip: text;\n}\n\n.gradient-text-light {\n  background: linear-gradient(135deg, hsl(142 52% 34%) 0%, hsl(142 48% 30%) 100%);\n  -webkit-background-clip: text;\n  -webkit-text-fill-color: transparent;\n  background-clip: text;\n}\n\n/* ============================================================\n   PRINT STYLES — Dossier and Report pages\n   ============================================================ */\n@media print {\n  @page {\n    margin: 18mm 16mm;\n    size: A4;\n  }\n\n  * {\n    -webkit-print-color-adjust: exact !important;\n    print-color-adjust: exact !important;\n  }\n\n  body {\n    background: #ffffff !important;\n    color: #111111 !important;\n    font-size: 11pt;\n  }\n\n  nav,\n  .no-print {\n    display: none !important;\n  }\n\n  .gradient-text,\n  .gradient-text-light {\n    -webkit-text-fill-color: #111111 !important;\n    background: none !important;\n    color: #111111 !important;\n  }\n\n  [data-testid=\"print-target\"] {\n    max-width: 100% !important;\n    padding: 0 !important;\n    margin: 0 !important;\n  }\n\n  .rounded-xl,\n  .rounded-lg {\n    border-radius: 4px !important;\n  }\n\n  .pitch-slide [style] {\n    opacity: 1 !important;\n    transform: none !important;\n  }\n\n  .bg-card,\n  .bg-background,\n  .bg-muted {\n    background-color: #ffffff !important;\n  }\n\n  .bg-primary\\/5,\n  .bg-primary\\/10 {\n    background-color: #f0f8ff !important;\n  }\n\n  .text-muted-foreground {\n    color: #444444 !important;\n  }\n\n  .text-foreground {\n    color: #111111 !important;\n  }\n\n  .text-primary {\n    color: #2a7a45 !important;\n  }\n\n  .border-card-border,\n  .border-primary\\/20,\n  .border-primary\\/15 {\n    border-color: #cccccc !important;\n  }\n\n  .space-y-6 > * + * {\n    margin-top: 16pt !important;\n  }\n\n  .space-y-4 > * + * {\n    margin-top: 10pt !important;\n  }\n\n  .space-y-3 > * + * {\n    margin-top: 8pt !important;\n  }\n\n  .grid.sm\\\\:grid-cols-3 {\n    display: block !important;\n  }\n\n  [data-testid^=\"report-asset-\"] {\n    page-break-inside: avoid;\n  }\n\n  [data-testid=\"dossier-narrative-panel\"] {\n    page-break-inside: avoid;\n  }\n\n  .score-badge,\n  [data-testid=\"score-badge\"] {\n    page-break-inside: avoid;\n  }\n\n  a {\n    color: #0070a8 !important;\n    text-decoration: underline;\n  }\n\n  body:has(.pitch-deck) {\n    background: #0d1117 !important;\n  }\n\n  .pitch-deck {\n    overflow: visible !important;\n    height: auto !important;\n    scroll-snap-type: none !important;\n  }\n\n  .pitch-slide {\n    height: 100vh !important;\n    min-height: 100vh !important;\n    page-break-after: always;\n    -moz-column-break-after: page;\n         break-after: page;\n    page-break-inside: avoid;\n    -moz-column-break-inside: avoid;\n         break-inside: avoid;\n    background: #0d1117 !important;\n    color: #e6edf3 !important;\n  }\n\n  .pitch-slide:last-child {\n    page-break-after: auto;\n    -moz-column-break-after: auto;\n         break-after: auto;\n  }\n\n  .pitch-nav,\n  .pitch-export {\n    display: none !important;\n  }\n\n  .pitch-deck * {\n    -webkit-print-color-adjust: exact !important;\n    print-color-adjust: exact !important;\n    color-adjust: exact !important;\n  }\n\n  .pitch-deck .bg-card,\n  .pitch-deck .bg-background,\n  .pitch-deck .bg-muted {\n    background-color: inherit !important;\n  }\n\n  .pitch-deck .text-foreground {\n    color: inherit !important;\n  }\n\n  .pitch-deck .text-muted-foreground {\n    color: #8b949e !important;\n  }\n\n  .pitch-deck body {\n    background: #0d1117 !important;\n  }\n}\n\n/* ============================================================\n   ONE-PAGER PRINT STYLES\n   ============================================================ */\n@media print {\n  body:has([data-testid=\"one-pager-document\"]) {\n    background: #ffffff !important;\n    margin: 0 !important;\n    padding: 0 !important;\n  }\n\n  body:has([data-testid=\"one-pager-document\"]) > div {\n    min-height: unset !important;\n    padding: 0 !important;\n    background: #ffffff !important;\n    display: block !important;\n    box-shadow: none !important;\n  }\n\n  .no-print {\n    display: none !important;\n  }\n\n  [data-testid=\"one-pager-document\"] {\n    width: 100% !important;\n    max-width: 100% !important;\n    box-shadow: none !important;\n    border-radius: 0 !important;\n    page-break-inside: avoid;\n    -moz-column-break-inside: avoid;\n         break-inside: avoid;\n  }\n\n  @page {\n    margin: 10mm 8mm;\n  }\n}\n\n/* ============================================================\n   GLASS PILL BUTTONS — hero CTAs with emerald outline on hover\n   ============================================================ */\n\n.glass-btn,\n.glass-btn-wrap {\n  position: relative;\n  display: inline-flex;\n  padding: 1.5px;\n  border-radius: 9999px;\n  overflow: hidden;\n  background: transparent;\n  transition: background 0.18s ease;\n}\n\n.glass-btn:hover,\n.glass-btn-wrap:hover {\n  background: hsl(142 52% 36%);\n}\n\n.glass-btn-inner {\n  position: relative;\n  z-index: 1;\n  display: inline-flex;\n  align-items: center;\n  gap: 0.5rem;\n  padding: 0.625rem 1.75rem;\n  border-radius: 9999px;\n  background: rgba(255, 255, 255, 0.78);\n  border: 1px solid rgba(0, 0, 0, 0.08);\n  color: hsl(var(--foreground));\n  font-size: 1rem;\n  font-weight: 600;\n  cursor: pointer;\n  transition: background 0.18s ease;\n  white-space: nowrap;\n  min-height: 48px;\n}\n\n.glass-btn-inner:hover {\n  background: rgba(255, 255, 255, 0.94);\n}\n\n.dark .glass-btn-inner {\n  background: rgba(255, 255, 255, 0.09);\n  border: 1px solid rgba(255, 255, 255, 0.14);\n  color: white;\n}\n\n.dark .glass-btn-inner:hover {\n  background: rgba(255, 255, 255, 0.15);\n}\n\n.file\\:border-0::file-selector-button {\n  border-width: 0px;\n}\n\n.file\\:bg-transparent::file-selector-button {\n  background-color: transparent;\n}\n\n.file\\:text-sm::file-selector-button {\n  font-size: 0.875rem;\n  line-height: 1.25rem;\n}\n\n.file\\:font-medium::file-selector-button {\n  font-weight: 500;\n}\n\n.file\\:text-foreground::file-selector-button {\n  --tw-text-opacity: 1;\n  color: hsl(var(--foreground) / var(--tw-text-opacity, 1));\n}\n\n.placeholder\\:text-gray-400\\/80::-moz-placeholder {\n  color: rgb(156 163 175 / 0.8);\n}\n\n.placeholder\\:text-gray-400\\/80::placeholder {\n  color: rgb(156 163 175 / 0.8);\n}\n\n.placeholder\\:text-muted-foreground::-moz-placeholder {\n  --tw-text-opacity: 1;\n  color: hsl(var(--muted-foreground) / var(--tw-text-opacity, 1));\n}\n\n.placeholder\\:text-muted-foreground::placeholder {\n  --tw-text-opacity: 1;\n  color: hsl(var(--muted-foreground) / var(--tw-text-opacity, 1));\n}\n\n.placeholder\\:text-muted-foreground\\/60::-moz-placeholder {\n  color: hsl(var(--muted-foreground) / 0.6);\n}\n\n.placeholder\\:text-muted-foreground\\/60::placeholder {\n  color: hsl(var(--muted-foreground) / 0.6);\n}\n\n.placeholder\\:text-white\\/30::-moz-placeholder {\n  color: rgb(255 255 255 / 0.3);\n}\n\n.placeholder\\:text-white\\/30::placeholder {\n  color: rgb(255 255 255 / 0.3);\n}\n\n.after\\:pointer-events-none::after {\n  content: var(--tw-content);\n  pointer-events: none;\n}\n\n.after\\:absolute::after {\n  content: var(--tw-content);\n  position: absolute;\n}\n\n.after\\:-inset-2::after {\n  content: var(--tw-content);\n  inset: -0.5rem;\n}\n\n.after\\:inset-0::after {\n  content: var(--tw-content);\n  inset: 0px;\n}\n\n.after\\:inset-y-0::after {\n  content: var(--tw-content);\n  top: 0px;\n  bottom: 0px;\n}\n\n.after\\:left-1\\/2::after {\n  content: var(--tw-content);\n  left: 50%;\n}\n\n.after\\:block::after {\n  content: var(--tw-content);\n  display: block;\n}\n\n.after\\:w-1::after {\n  content: var(--tw-content);\n  width: 0.25rem;\n}\n\n.after\\:w-\\[2px\\]::after {\n  content: var(--tw-content);\n  width: 2px;\n}\n\n.after\\:-translate-x-1\\/2::after {\n  content: var(--tw-content);\n  --tw-translate-x: -50%;\n  transform: translate(var(--tw-translate-x), var(--tw-translate-y)) rotate(var(--tw-rotate)) skewX(var(--tw-skew-x)) skewY(var(--tw-skew-y)) scaleX(var(--tw-scale-x)) scaleY(var(--tw-scale-y));\n}\n\n.after\\:rounded-full::after {\n  content: var(--tw-content);\n  border-radius: 9999px;\n}\n\n.after\\:border::after {\n  content: var(--tw-content);\n  border-width: 1px;\n}\n\n.after\\:border-black\\/10::after {\n  content: var(--tw-content);\n  border-color: rgb(0 0 0 / 0.1);\n}\n\n.after\\:content-\\[\\'\\'\\]::after {\n  --tw-content: '';\n  content: var(--tw-content);\n}\n\n