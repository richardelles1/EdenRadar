# ── Required: Database ────────────────────────────────────────────────────────
# PostgreSQL connection string (Supabase project → Settings → Database → URI)
SUPABASE_DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

# ── Required: Supabase Auth ───────────────────────────────────────────────────
VITE_SUPABASE_URL=https://[ref].supabase.co
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
# Only set if using a non-standard Supabase project URL (same as VITE_SUPABASE_URL)
# SUPABASE_URL=

# ── Required: AI / LLM ────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
# Optional override for Azure OpenAI or compatible endpoint
# AI_INTEGRATIONS_OPENAI_API_KEY=
# AI_INTEGRATIONS_OPENAI_BASE_URL=

# ── Required: Email ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_ADDRESS=noreply@yourdomain.com

# ── Required: Admin Access ────────────────────────────────────────────────────
# Comma-separated list of Supabase user IDs with admin access
ADMIN_EMAILS=user-id-1,user-id-2
# Optional: separate notification-only list (defaults to ADMIN_EMAILS)
# ADMIN_NOTIFICATION_EMAILS=

# ── Optional: Billing (Stripe) ────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_INDIVIDUAL=price_...
STRIPE_PRICE_TEAM5=price_...
STRIPE_PRICE_TEAM10=price_...
STRIPE_PRICE_EDENMARKET=price_...

# ── Optional: Error Tracking ──────────────────────────────────────────────────
SENTRY_DSN=https://...@sentry.io/...

# ── Optional: External Data APIs ─────────────────────────────────────────────
LENS_API_KEY=
USPTO_ODP_API_KEY=
IEDISON_API_KEY=
IEEE_API_KEY=
OPENFDA_API_KEY=

# ── Optional: Security & Routing ─────────────────────────────────────────────
# HMAC secret for digest unsubscribe tokens
UNSUBSCRIBE_TOKEN_SECRET=
# Allowed CORS origin beyond *.replit.app (e.g. https://app.yourdomain.com)
ALLOWED_ORIGIN=
# Base URL for share links and emails (e.g. https://app.yourdomain.com)
APP_URL=
APP_BASE_URL=
PUBLIC_BASE_URL=

# ── Optional: Scraper / Infrastructure ───────────────────────────────────────
# HTTP proxy for scraper requests (format: http://user:pass@host:port)
SCRAPER_PROXY_URL=
# Internal Replit connectivity (set automatically on Replit)
# REPLIT_CONNECTORS_HOSTNAME=
# REPL_IDENTITY=
# WEB_REPL_RENEWAL=

# ── Optional: External Cron Trigger ──────────────────────────────────────────
# Long random string used by Supabase pg_cron to authenticate /api/internal/sweep-trigger.
# Generate with: openssl rand -hex 32
# Must match the value stored in Supabase's pg_cron job (see db/migrations/sweep_cron.sql).
SWEEP_TRIGGER_SECRET=

# ── Optional: Feature Flags ───────────────────────────────────────────────────
# Internal API key for server-to-server calls (if CORE_API_KEY auth is used)
CORE_API_KEY=
# Alert evaluation interval in minutes (default: 5)
ALERT_EVAL_INTERVAL_MIN=5
# Maximum assets to enrich per scheduler cycle (default: unlimited)
# ENRICH_MAX_PER_CYCLE=
# Pino log level (default: info) — valid: trace, debug, info, warn, error, fatal
LOG_LEVEL=info
# Bypass auth for smoke testing (never set in production)
# ENABLE_SMOKE_AUTH_BYPASS=

# ── Optional: Eden AI Feature Flags ──────────────────────────────────────────
# EDEN_CONFIDENCE_AWARE_RANKING=true
# EDEN_HYBRID_SEARCH=true
# EDEN_RELEVANCE_CLASSIFIER_V2=true
# EDEN_RELEVANCE_CLASSIFIER_THRESHOLD=0.5
# EDEN_USER_FEEDBACK_OFFSET=0

# ── Runtime ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
